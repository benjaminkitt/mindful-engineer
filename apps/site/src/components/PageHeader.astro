---
interface Props {
  kicker: string;
  title: string;
  summary: string;
  meta?: Array<{ label: string; value: string | number }>;
}

const { kicker, title, summary, meta = [] } = Astro.props;
---

<section class="hero">
  <div class="hero__kicker">{kicker}</div>
  <h1>{title}</h1>
  <p class="hero__summary">{summary}</p>
  {meta.length > 0 && (
    <dl class="hero__meta">
      {meta.map((item) => (
        <div>
          <dt>{item.label}</dt>
          <dd>{item.value}</dd>
        </div>
      ))}
    </dl>
  )}
</section>
