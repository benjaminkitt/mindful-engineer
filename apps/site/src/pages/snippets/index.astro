---
import PageHeader from '@/components/PageHeader.astro';
import { formatDate, getEntriesByType, getEntryUrl } from '@/lib/content';
import PublicLayout from '@/layouts/PublicLayout.astro';

const snippets = getEntriesByType('snippet');
---

<PublicLayout title="Snippets" pathname="/snippets">
  <PageHeader
    kicker="code-forward · snippets"
    title="Snippets"
    summary="Compact technical fragments with just enough context to keep them useful later."
    meta={[{ label: 'published', value: snippets.length }]}
  />

  <div class="list-stack">
    {snippets.map((snippet) => (
      <a href={getEntryUrl(snippet)} class="list-row">
        <div class="list-row__date">{formatDate(snippet.publishedAt)}<br />{snippet.language}</div>
        <div class="list-row__body">
          <h2>{snippet.title}</h2>
          <p>{snippet.summary}</p>
        </div>
      </a>
    ))}
  </div>
</PublicLayout>
