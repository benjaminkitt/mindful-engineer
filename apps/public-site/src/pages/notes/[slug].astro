---
import ElsewhereLinks from "../../components/ElsewhereLinks.astro";
import { formatDisplayDateTime, getEntryPath, getNotes, type Note } from "../../data/site";
import { getElsewhereDestinationsForPath } from "../../data/syndication-state";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const notes = await getNotes();
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props as { note: Note };
const canonicalPath = getEntryPath(note);
const elsewhere = getElsewhereDestinationsForPath(canonicalPath);
---
<BaseLayout title="Note | The Mindful Engineer" description={note.body} path={canonicalPath}>
  <div class="container">
    <div class="essay-header" style="max-width: var(--measure-narrow);">
      <div class="essay-kicker">
        <span>note</span>
        <span>/</span>
        <span>{formatDisplayDateTime(note.date)}</span>
      </div>
    </div>
    <div class="essay-body" style="max-width: var(--measure-narrow);">
      <p style="font-size: 26px; line-height: 1.45; font-style: italic;">{note.body}</p>
      <ElsewhereLinks destinations={elsewhere} />
    </div>
  </div>
</BaseLayout>
