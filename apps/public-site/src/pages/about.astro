---
import InstrumentFigure from "../components/InstrumentFigure.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAboutPage } from "../data/site";

const aboutPage = await getAboutPage();
---
<BaseLayout title="About | The Mindful Engineer" description={aboutPage.deck} path="/about">
  <div class="container">
    <section class="hero" style="padding-top: var(--s-5); padding-bottom: var(--s-6);">
      <InstrumentFigure variant="vitruvian" />
      <div class="hero-kicker"><span>about / colophon</span></div>
      <h1 class="hero-title" style="font-size: clamp(32px, 4.5vw, 52px);">{aboutPage.title}</h1>
      <p class="hero-sub">{aboutPage.deck}</p>
    </section>

    <div class="about-grid">
      <div class="about-portrait">
        <span>portrait</span>
      </div>
      <div class="about-text">
        {aboutPage.body.map((paragraph) => (
          <p>{paragraph}</p>
        ))}

        <dl class="about-facts">
          {aboutPage.facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </div>
</BaseLayout>
